<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>{{brand-name}} · lockup horizontal on ink · 1800×600</title>
    <link rel="stylesheet" href="../shared.css" />
    <style>
      body { margin: 0; }
      .board { width: 1800px; height: 600px; position: relative; display: grid; place-items: center; overflow: hidden; background: var(--brand-bg); }
      .lock { display: flex; align-items: center; gap: 72px; }
      .symbol { width: 360px; height: 360px; object-fit: contain; }
      .wm { font-family: var(--font-display); font-weight: {{font-display-weight-display}}; font-size: 320px; line-height: 0.85; letter-spacing: {{font-display-letter-spacing}}; color: var(--brand-fg); }
      .wm .accent { color: var(--brand-accent); }
    </style>
  </head>
  <body data-width="1800" data-height="600">
    <div class="board">
      <div class="lock">
        <img class="symbol" src="../recursos/logo-white.png" alt="" />
        <span class="wm">{{wordmark-first}}<span class="accent">{{wordmark-accent}}</span></span>
      </div>
    </div>
  </body>
</html>
