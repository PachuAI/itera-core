<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>{{brand-name}} · symbol on white · 1080×1080</title>
    <link rel="stylesheet" href="../shared.css" />
    <style>
      body { margin: 0; }
      .board { width: 1080px; height: 1080px; position: relative; display: grid; place-items: center; overflow: hidden; background: var(--brand-white); }
      .symbol { width: 78%; height: 78%; object-fit: contain; }
    </style>
  </head>
  <body data-width="1080" data-height="1080">
    <div class="board">
      <img class="symbol" src="../assets/logo-black.png" alt="{{brand-name}} symbol" />
    </div>
  </body>
</html>
