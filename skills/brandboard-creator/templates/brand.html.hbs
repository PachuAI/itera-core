<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=1920" />
    <title>{{brand-name}} · brandboard</title>
    <link rel="stylesheet" href="shared.css" />
    <style>
      /* ═════════════════════════════════════════════════════════════════
       * brand.html — source of truth visual de {{brand-name}}.
       * Generado por brandboard-creator ({{brand-meta-established}}).
       * Ancho fijo 1920. Altura dinámica.
       * ═════════════════════════════════════════════════════════════════ */
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        width: 1920px;
        background: var(--brand-bg);
        color: var(--brand-fg);
        font-family: var(--font-ui);
        -webkit-font-smoothing: antialiased;
      }

      .bg-atmo {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        background: radial-gradient(
          circle at 50% 12%,
          {{color-accent-atmo-mid}} 0%,
          {{color-accent-atmo-soft}} 32%,
          transparent 60%
        );
        filter: blur(40px);
      }

      .page { position: relative; z-index: 1; padding: 120px 120px 160px; display: flex; flex-direction: column; gap: 140px; }
      section { display: flex; flex-direction: column; gap: 40px; }

      .eye { font-family: var(--font-ui); font-weight: 500; font-size: 16px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--brand-accent); display: inline-flex; align-items: center; gap: 12px; }
      .eye .dot { width: 9px; height: 9px; border-radius: 50%; background: var(--brand-accent); box-shadow: 0 0 12px var(--brand-accent-glow); }
      h1 { margin: 0; font-family: var(--font-display); font-weight: {{font-display-weight-display}}; font-size: 96px; line-height: 1; letter-spacing: {{font-display-letter-spacing}}; color: var(--brand-fg); }
      h2 { margin: 0; font-family: var(--font-display); font-weight: 600; font-size: 56px; line-height: 1.04; letter-spacing: -0.015em; color: var(--brand-fg); }
      h3 { margin: 0; font-family: var(--font-display); font-weight: 600; font-size: 28px; line-height: 1.1; letter-spacing: -0.01em; color: var(--brand-fg); }
      .lead { margin: 0; font-family: var(--font-ui); font-weight: 400; font-size: 20px; line-height: 1.55; color: var(--brand-fg-muted); max-width: 920px; }
      .section-head { display: flex; flex-direction: column; gap: 20px; padding-bottom: 12px; border-bottom: 1px solid var(--brand-border); }

      /* HERO */
      .hero { display: flex; flex-direction: column; gap: 48px; padding-bottom: 64px; border-bottom: 1px solid var(--brand-border); }
      .hero .lock-hero { display: flex; align-items: center; gap: 32px; }
      .hero .lock-hero img { width: 180px; height: 180px; object-fit: contain; }
      .hero .lock-hero .wm { font-family: var(--font-display); font-weight: {{font-display-weight-display}}; font-size: 180px; line-height: 0.85; letter-spacing: {{font-display-letter-spacing}}; color: var(--brand-fg); }
      .hero .lock-hero .wm .ac { color: var(--brand-accent); }
      .hero .punch { font-family: var(--font-display); font-weight: 600; font-size: 72px; line-height: 1.08; letter-spacing: -0.015em; color: var(--brand-fg); max-width: 1300px; margin: 0; }
      .hero .punch b { font-weight: 800; color: var(--brand-accent); }
      .hero .meta { display: flex; gap: 40px; flex-wrap: wrap; color: var(--brand-fg-dim); font-size: 16px; font-family: var(--font-ui); }
      .hero .meta span { display: inline-flex; align-items: center; gap: 10px; }
      .hero .meta b { color: var(--brand-fg-muted); font-weight: 500; }

      /* LOGO GRID */
      .logo-grid { display: grid; grid-template-columns: 180px repeat(5, 1fr); gap: 24px; align-items: stretch; }
      .logo-grid .row-label { font-family: var(--font-ui); font-weight: 600; font-size: 18px; color: var(--brand-fg); text-transform: lowercase; display: flex; align-items: center; padding-left: 4px; }
      .logo-grid .col-label { font-family: var(--font-ui); font-weight: 500; font-size: 13px; color: var(--brand-fg-dim); text-transform: uppercase; letter-spacing: 0.18em; text-align: center; padding: 14px 0 0; }
      .logo-cell { display: grid; place-items: center; border-radius: 18px; overflow: hidden; aspect-ratio: 1 / 1; position: relative; }
      .logo-cell.sq-h { aspect-ratio: 3 / 1; }
      .logo-cell.on-ink { background: var(--brand-bg); border: 1px solid var(--brand-border); }
      .logo-cell.on-white { background: var(--brand-white); }
      .logo-cell.on-wa { background: var(--brand-accent); }
      .logo-cell.on-cream { background: var(--brand-cream); }
      .logo-cell.on-navy { background: var(--brand-navy); }
      .logo-cell img { width: 78%; height: 78%; object-fit: contain; }
      .logo-cell .wm { font-family: var(--font-display); font-weight: {{font-display-weight-display}}; font-size: 72px; line-height: 0.85; letter-spacing: {{font-display-letter-spacing}}; }
      .logo-cell .wm .ac { color: var(--brand-accent); }
      .logo-cell.on-ink .wm, .logo-cell.on-navy .wm { color: var(--brand-fg); }
      .logo-cell.on-white .wm, .logo-cell.on-cream .wm { color: var(--brand-ink); }
      .logo-cell.on-wa .wm { color: var(--brand-accent-ink); }
      .logo-cell.on-wa .wm .ac { color: var(--brand-white); }
      .lock-inline { display: flex; align-items: center; gap: 16px; }
      .lock-inline img { width: 64px !important; height: 64px !important; }
      .lock-inline .wm { font-size: 56px; }
      .lock-stacked-inline { display: flex; flex-direction: column; align-items: center; gap: 14px; }
      .lock-stacked-inline img { width: 120px !important; height: 120px !important; }
      .lock-stacked-inline .wm { font-size: 42px; }

      /* PALETTE */
      .palette-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
      .swatch { border-radius: 20px; overflow: hidden; border: 1px solid var(--brand-border); display: flex; flex-direction: column; height: 280px; }
      .swatch .fill { flex: 1; display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-weight: {{font-display-weight-display}}; font-size: 42px; letter-spacing: {{font-display-letter-spacing}}; }
      .swatch .meta { padding: 16px 20px 18px; background: var(--brand-surface); display: flex; flex-direction: column; gap: 6px; border-top: 1px solid var(--brand-border); }
      .swatch .meta .name { font-family: var(--font-ui); font-weight: 600; font-size: 15px; color: var(--brand-fg); }
      .swatch .meta .hex { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 13px; color: var(--brand-fg-muted); }
      .swatch .meta .role { font-family: var(--font-ui); font-weight: 400; font-size: 13px; color: var(--brand-fg-dim); line-height: 1.4; }

      .fill-ink { background: {{color-ink}}; color: {{color-white}}; }
      .fill-white { background: {{color-white}}; color: {{color-ink}}; }
      .fill-wa { background: {{color-accent}}; color: {{color-accent-ink}}; }
      .fill-wa-ink { background: {{color-accent-ink}}; color: {{color-accent}}; }
      .fill-cream { background: {{color-cream}}; color: {{color-ink}}; }
      .fill-navy { background: {{color-navy}}; color: {{color-white}}; }
      .fill-slate { background: {{color-slate}}; color: {{color-white}}; }

      /* COMBOS */
      .combos { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
      .combo { border-radius: 16px; overflow: hidden; height: 180px; display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-weight: 600; font-size: 38px; letter-spacing: -0.01em; position: relative; }
      .combo::after { content: attr(data-label); position: absolute; bottom: 14px; left: 16px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; font-weight: normal; letter-spacing: 0; opacity: 0.55; text-transform: none; }
      .combo-avoid { border-radius: 16px; overflow: hidden; height: 180px; display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-weight: 600; font-size: 30px; letter-spacing: -0.01em; position: relative; border: 1px dashed rgba(255, 80, 80, 0.4); }
      .combo-avoid::before { content: '✗'; position: absolute; top: 12px; right: 16px; color: #ff5858; font-size: 22px; font-weight: 700; }
      .combo-avoid::after { content: attr(data-label); position: absolute; bottom: 14px; left: 16px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; font-weight: normal; letter-spacing: 0; opacity: 0.7; text-transform: none; }

      /* TYPOGRAPHY */
      .type-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; }
      .type-card { background: var(--brand-surface); border: 1px solid var(--brand-border); border-radius: 20px; padding: 40px; display: flex; flex-direction: column; gap: 28px; }
      .type-card .family-name { font-size: 14px; color: var(--brand-fg-dim); letter-spacing: 0.2em; text-transform: uppercase; }
      .type-card .family { font-family: inherit; font-weight: 700; font-size: 96px; line-height: 0.95; letter-spacing: -0.02em; color: var(--brand-fg); margin: 0; }
      .type-card .role { color: var(--brand-fg-muted); font-size: 16px; line-height: 1.5; }
      .weights { display: flex; flex-direction: column; gap: 12px; }
      .weights .w { display: flex; align-items: baseline; gap: 18px; border-top: 1px solid var(--brand-border); padding-top: 12px; }
      .weights .w .num { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 13px; color: var(--brand-fg-dim); width: 56px; }
      .weights .w .sample { font-size: 28px; letter-spacing: -0.01em; color: var(--brand-fg); }
      .weights .w .use { font-family: var(--font-ui); font-size: 13px; color: var(--brand-fg-dim); margin-left: auto; text-align: right; max-width: 240px; line-height: 1.35; }

      .family-display .family, .family-display .sample { font-family: var(--font-display); }
      .family-ui .family, .family-ui .sample { font-family: var(--font-ui); }

      /* RULES */
      .rules-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
      .rule { background: var(--brand-surface); border: 1px solid var(--brand-border); border-radius: 18px; padding: 32px; display: flex; flex-direction: column; gap: 16px; }
      .rule h3 { font-size: 22px; }
      .rule p { margin: 0; color: var(--brand-fg-muted); font-size: 15px; line-height: 1.55; font-family: var(--font-ui); }
      .rule ul { margin: 0; padding-left: 20px; color: var(--brand-fg-muted); font-size: 15px; line-height: 1.7; font-family: var(--font-ui); }

      .dont { border-color: rgba(255, 88, 88, 0.35); }
      .dont h3::before { content: '✗  '; color: #ff5858; }

      /* VOICE */
      .voice-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
      .voice-card { background: var(--brand-surface); border: 1px solid var(--brand-border); border-radius: 18px; padding: 32px; }
      .voice-card h3 { font-size: 24px; margin-bottom: 18px; }
      .voice-card .quote { font-family: var(--font-display); font-weight: 600; font-size: 40px; line-height: 1.08; color: var(--brand-fg); letter-spacing: -0.015em; margin-bottom: 14px; }
      .voice-card .quote b { font-weight: 800; color: var(--brand-accent); }
      .voice-card ul { margin: 0; padding-left: 20px; color: var(--brand-fg-muted); font-size: 15px; line-height: 1.7; font-family: var(--font-ui); }
      .voice-card code { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 14px; background: var(--brand-accent-soft); color: var(--brand-accent); padding: 2px 8px; border-radius: 6px; }

      /* TOKENS TABLE */
      .tokens { background: var(--brand-surface); border: 1px solid var(--brand-border); border-radius: 18px; overflow: hidden; }
      .tokens table { width: 100%; border-collapse: collapse; }
      .tokens thead th { text-align: left; padding: 20px 28px; font-family: var(--font-ui); font-weight: 600; font-size: 13px; color: var(--brand-fg-dim); text-transform: uppercase; letter-spacing: 0.18em; background: rgba(255,255,255,0.02); border-bottom: 1px solid var(--brand-border); }
      .tokens tbody td { padding: 18px 28px; font-family: var(--font-ui); font-size: 15px; color: var(--brand-fg-muted); border-bottom: 1px solid var(--brand-border); vertical-align: middle; }
      .tokens tbody tr:last-child td { border-bottom: 0; }
      .tokens td code { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 14px; color: var(--brand-fg); }
      .tokens td .dot-sw { display: inline-block; width: 20px; height: 20px; border-radius: 6px; vertical-align: middle; margin-right: 12px; border: 1px solid rgba(255,255,255,0.1); }

      .foot-meta { display: flex; justify-content: space-between; padding-top: 40px; border-top: 1px solid var(--brand-border); font-family: var(--font-ui); font-size: 14px; color: var(--brand-fg-dim); }
      .foot-meta a { color: var(--brand-accent); text-decoration: none; }
    </style>
  </head>
  <body>
    <div class="bg-atmo"></div>
    <div class="page">

      <section class="hero">
        <div class="eye"><span class="dot"></span><span>{{brand-name}} · brandboard</span></div>
        <div class="lock-hero">
          <img src="assets/logo-white.png" alt="" />
          <span class="wm">{{wordmark-first}}<span class="ac">{{wordmark-accent}}</span></span>
        </div>
        <p class="punch">{{punchline-html}}</p>
        <div class="meta">
          <span><b>brand {{brand-meta-version}}</b> · established {{brand-meta-established}}</span>
          <span><b>tipografía</b> · {{font-display-family}} + {{font-ui-family}}</span>
          <span><b>accent</b> · {{color-accent}}</span>
          <span><b>source</b> · {{brand-source-doc}}</span>
        </div>
      </section>

      <section>
        <div class="section-head">
          <div class="eye"><span class="dot"></span><span>01 · logo system</span></div>
          <h2>symbol · wordmark · lockup</h2>
          <p class="lead">
            Tres formas canónicas sobre cinco fondos válidos. El <b>symbol</b> es la silueta del isotipo.
            El <b>wordmark</b> es "{{brand-name}}" en {{font-display-family}} {{font-display-weight-display}} con "{{wordmark-accent}}" en accent.
            El <b>lockup</b> combina los dos — el symbol a la izquierda, siempre.
          </p>
        </div>

        <div class="logo-grid">
          <div class="row-label"></div>
          <div class="col-label">on ink</div>
          <div class="col-label">on white</div>
          <div class="col-label">on accent</div>
          <div class="col-label">on cream</div>
          <div class="col-label">on navy</div>

          <div class="row-label">symbol</div>
          <div class="logo-cell on-ink"><img src="assets/logo-white.png" alt="" /></div>
          <div class="logo-cell on-white"><img src="assets/logo-black.png" alt="" /></div>
          <div class="logo-cell on-wa"><img src="assets/logo-white.png" alt="" /></div>
          <div class="logo-cell on-cream"><img src="assets/logo-black.png" alt="" /></div>
          <div class="logo-cell on-navy"><img src="assets/logo-white.png" alt="" /></div>

          <div class="row-label">wordmark</div>
          <div class="logo-cell sq-h on-ink"><span class="wm">{{wordmark-first}}<span class="ac">{{wordmark-accent}}</span></span></div>
          <div class="logo-cell sq-h on-white"><span class="wm">{{wordmark-first}}<span class="ac">{{wordmark-accent}}</span></span></div>
          <div class="logo-cell sq-h on-wa"><span class="wm">{{wordmark-first}}<span class="ac">{{wordmark-accent}}</span></span></div>
          <div class="logo-cell sq-h on-cream"><span class="wm">{{wordmark-first}}<span class="ac">{{wordmark-accent}}</span></span></div>
          <div class="logo-cell sq-h on-navy"><span class="wm">{{wordmark-first}}<span class="ac">{{wordmark-accent}}</span></span></div>

          <div class="row-label">lockup h</div>
          <div class="logo-cell sq-h on-ink"><div class="lock-inline"><img src="assets/logo-white.png" alt="" /><span class="wm">{{wordmark-first}}<span class="ac">{{wordmark-accent}}</span></span></div></div>
          <div class="logo-cell sq-h on-white"><div class="lock-inline"><img src="assets/logo-black.png" alt="" /><span class="wm">{{wordmark-first}}<span class="ac">{{wordmark-accent}}</span></span></div></div>
          <div class="logo-cell sq-h on-wa"><div class="lock-inline"><img src="assets/logo-white.png" alt="" /><span class="wm">{{wordmark-first}}<span class="ac">{{wordmark-accent}}</span></span></div></div>
          <div class="logo-cell sq-h on-cream"><div class="lock-inline"><img src="assets/logo-black.png" alt="" /><span class="wm">{{wordmark-first}}<span class="ac">{{wordmark-accent}}</span></span></div></div>
          <div class="logo-cell sq-h on-navy"><div class="lock-inline"><img src="assets/logo-white.png" alt="" /><span class="wm">{{wordmark-first}}<span class="ac">{{wordmark-accent}}</span></span></div></div>

          <div class="row-label">lockup ▤</div>
          <div class="logo-cell on-ink"><div class="lock-stacked-inline"><img src="assets/logo-white.png" alt="" /><span class="wm">{{wordmark-first}}<span class="ac">{{wordmark-accent}}</span></span></div></div>
          <div class="logo-cell on-white"><div class="lock-stacked-inline"><img src="assets/logo-black.png" alt="" /><span class="wm">{{wordmark-first}}<span class="ac">{{wordmark-accent}}</span></span></div></div>
          <div class="logo-cell on-wa"><div class="lock-stacked-inline"><img src="assets/logo-white.png" alt="" /><span class="wm">{{wordmark-first}}<span class="ac">{{wordmark-accent}}</span></span></div></div>
          <div class="logo-cell on-cream"><div class="lock-stacked-inline"><img src="assets/logo-black.png" alt="" /><span class="wm">{{wordmark-first}}<span class="ac">{{wordmark-accent}}</span></span></div></div>
          <div class="logo-cell on-navy"><div class="lock-stacked-inline"><img src="assets/logo-white.png" alt="" /><span class="wm">{{wordmark-first}}<span class="ac">{{wordmark-accent}}</span></span></div></div>
        </div>
      </section>

      <section>
        <div class="section-head">
          <div class="eye"><span class="dot"></span><span>02 · paleta</span></div>
          <h2>siete colores · roles claros</h2>
          <p class="lead">Los tokens brand definen la fuente. De acá derivan todos los tokens UI bajo <code style="background:rgba(255,255,255,0.04); padding:2px 8px; border-radius:6px; color:var(--brand-fg);">--brand-*</code>.</p>
        </div>

        <div class="palette-grid">
          <div class="swatch"><div class="fill fill-ink">Aa</div><div class="meta"><span class="name">ink</span><span class="hex">{{color-ink}}</span><span class="role">Texto principal. Fondo oscuro alternativo.</span></div></div>
          <div class="swatch"><div class="fill fill-white">Aa</div><div class="meta"><span class="name">white</span><span class="hex">{{color-white}}</span><span class="role">Fondo claro principal. Texto sobre fondos oscuros.</span></div></div>
          <div class="swatch"><div class="fill fill-wa">Aa</div><div class="meta"><span class="name">accent</span><span class="hex">{{color-accent}}</span><span class="role">Único acento activo. CTA, highlight, dot.</span></div></div>
          <div class="swatch"><div class="fill fill-wa-ink">Aa</div><div class="meta"><span class="name">accent-ink</span><span class="hex">{{color-accent-ink}}</span><span class="role">Texto sobre accent. Contraste WCAG AA.</span></div></div>
          <div class="swatch"><div class="fill fill-cream">Aa</div><div class="meta"><span class="name">cream</span><span class="hex">{{color-cream}}</span><span class="role">Fondo cálido secundario. Hero light alternativo.</span></div></div>
          <div class="swatch"><div class="fill fill-navy">Aa</div><div class="meta"><span class="name">navy</span><span class="hex">{{color-navy}}</span><span class="role">Fondo oscuro narrativo. Stories, contenido dramático.</span></div></div>
          <div class="swatch"><div class="fill fill-slate">Aa</div><div class="meta"><span class="name">slate</span><span class="hex">{{color-slate}}</span><span class="role">Surface oscura elevada. Cards sobre navy.</span></div></div>
        </div>
      </section>

      <section>
        <div class="section-head">
          <div class="eye"><span class="dot"></span><span>03 · combinaciones</span></div>
          <h2>qué juega · qué no</h2>
          <p class="lead">Cinco combinaciones validadas para texto + fondo. Las que no están se validan antes de usar.</p>
        </div>

        <h3 style="margin-top: 12px; color: var(--brand-fg-muted);">✓ válidas</h3>
        <div class="combos">
          <div class="combo fill-white" data-label="ink / white">ejemplo corto</div>
          <div class="combo fill-ink" data-label="white / ink">ejemplo corto</div>
          <div class="combo fill-wa" data-label="accent-ink / accent">llamado de acción</div>
          <div class="combo fill-cream" data-label="ink / cream">ejemplo corto</div>
          <div class="combo fill-navy" data-label="white / navy">ejemplo corto</div>
        </div>

        <h3 style="margin-top: 32px; color: var(--brand-fg-muted);">evitar</h3>
        <div class="combos">
          <div class="combo-avoid" style="background: var(--brand-accent); color: var(--brand-accent-ink);" data-label="accent full-page — satura">página entera en accent</div>
          <div class="combo-avoid" style="background: var(--brand-navy); color: var(--brand-slate); border-color: rgba(255,88,88,0.35);" data-label="navy + slate juntos">navy + slate sin separar</div>
          <div class="combo-avoid" style="background: var(--brand-accent); color: var(--brand-cream);" data-label="cream sobre accent — low contrast">cream sobre accent</div>
        </div>
      </section>

      <section>
        <div class="section-head">
          <div class="eye"><span class="dot"></span><span>04 · tipografía</span></div>
          <h2>{{font-display-family}} + {{font-ui-family}}</h2>
          <p class="lead">Dos familias. Display para headings y wordmark, UI para body, labels, CTA.</p>
        </div>

        <div class="type-grid">
          <div class="type-card family-display">
            <span class="family-name">display · headings</span>
            <p class="family">{{font-display-family}}</p>
            <p class="role">Headings, wordmark, punchlines. Cargada vía Google Fonts.</p>
            <div class="weights">
              <div class="w"><span class="num">400-500</span><span class="sample" style="font-weight:500;">pesos ligeros</span><span class="use">subtítulos largos</span></div>
              <div class="w"><span class="num">600</span><span class="sample" style="font-weight:600;">heading default</span><span class="use">H1/H2, cards</span></div>
              <div class="w"><span class="num">{{font-display-weight-display}}</span><span class="sample" style="font-weight:{{font-display-weight-display}};">{{brand-name}}</span><span class="use">wordmark principal</span></div>
              <div class="w"><span class="num">800</span><span class="sample" style="font-weight:800;">highlight</span><span class="use">palabras destacadas</span></div>
            </div>
          </div>
          <div class="type-card family-ui">
            <span class="family-name">UI · body</span>
            <p class="family">{{font-ui-family}}</p>
            <p class="role">Body, botones, nav, eyebrow, labels, chips. Cargada vía Google Fonts.</p>
            <div class="weights">
              <div class="w"><span class="num">400</span><span class="sample" style="font-weight:400;">body default</span><span class="use">párrafos, lead</span></div>
              <div class="w"><span class="num">500</span><span class="sample" style="font-weight:500;">eyebrow · label</span><span class="use">labels, nav, chips</span></div>
              <div class="w"><span class="num">600</span><span class="sample" style="font-weight:600;">CTA</span><span class="use">botones primarios, badges</span></div>
            </div>
          </div>
        </div>
      </section>

      <section>
        <div class="section-head">
          <div class="eye"><span class="dot"></span><span>05 · reglas del logo</span></div>
          <h2>respetar el sistema</h2>
          <p class="lead">El logo es la marca oficial. Procesado como PNG transparente master. No improvisar.</p>
        </div>

        <div class="rules-grid">
          <div class="rule"><h3>minimum size</h3><p>No usar el logo a menos de <b style="color:var(--brand-fg);">16px</b>. Debajo, sólo un cuadrado de color accent sin silueta.</p></div>
          <div class="rule"><h3>área de respeto</h3><p>Padding de <b style="color:var(--brand-fg);">8-12%</b> alrededor. No arrimar texto ni otros elementos al borde.</p></div>
          <div class="rule"><h3>orientación</h3><p>Conservar la orientación del isotipo original. <b style="color:var(--brand-fg);">NO flipped</b>, rotado o reflejado.</p></div>
          <div class="rule dont"><h3>nada de deformar</h3><ul><li>no rotar</li><li>no gradientes</li><li>no outlines</li><li>no sombras</li><li>no stretch</li></ul></div>
          <div class="rule dont"><h3>nada de tipografía custom</h3><p>El wordmark es <code style="font-family:ui-monospace; font-size:13px; background:var(--brand-accent-soft); color:var(--brand-accent); padding:2px 6px; border-radius:4px;">{{brand-name}}</code> en {{font-display-family}} {{font-display-weight-display}}. Sin variantes de casing distintas.</p></div>
          <div class="rule dont"><h3>nada de mezclar con otros logos</h3><p>El logo de {{brand-name}} no se compone con marcas de terceros sin aprobación explícita.</p></div>
        </div>
      </section>

      <section>
        <div class="section-head">
          <div class="eye"><span class="dot"></span><span>06 · voice & tone</span></div>
          <h2>cómo hablamos</h2>
          <p class="lead">La voz de {{brand-name}}. Adaptar estos bloques al tono real de la marca si es distinto al default.</p>
        </div>

        <div class="voice-grid">
          <div class="voice-card">
            <h3>punchline principal</h3>
            <p class="quote">{{punchline-html}}</p>
            <h3 style="margin-top:28px; font-size:18px;">variaciones autorizadas</h3>
            <ul>
              <li>{{voice-variation-1}}</li>
              <li>{{voice-variation-2}}</li>
              <li>{{voice-variation-3}}</li>
            </ul>
          </div>
          <div class="voice-card">
            <h3>reglas de tono</h3>
            <ul style="line-height:1.8;">
              <li>{{voice-rule-1}}</li>
              <li>{{voice-rule-2}}</li>
              <li>{{voice-rule-3}}</li>
              <li>{{voice-rule-4}}</li>
            </ul>
            <h3 style="margin-top:20px; font-size:18px;">highlights</h3>
            <ul><li>{{voice-highlights}}</li></ul>
          </div>
        </div>
      </section>

      <section>
        <div class="section-head">
          <div class="eye"><span class="dot"></span><span>07 · design tokens</span></div>
          <h2>variables CSS canónicas</h2>
          <p class="lead">La paleta brand se proyecta a la UI vía variables <code style="background:rgba(255,255,255,0.04); padding:2px 8px; border-radius:6px; color:var(--brand-fg);">--brand-*</code>. Definidas en <code style="background:rgba(255,255,255,0.04); padding:2px 8px; border-radius:6px; color:var(--brand-fg);">shared.css</code>.</p>
        </div>

        <div class="tokens">
          <table>
            <thead><tr><th>token</th><th>valor</th><th>uso</th></tr></thead>
            <tbody>
              <tr><td><code><span class="dot-sw" style="background:{{color-accent}};"></span>--brand-accent</code></td><td><code>{{color-accent}}</code></td><td>CTA bg, eyebrow, icon activo</td></tr>
              <tr><td><code><span class="dot-sw" style="background:{{color-accent-ink}};"></span>--brand-accent-ink</code></td><td><code>{{color-accent-ink}}</code></td><td>Texto sobre accent</td></tr>
              <tr><td><code><span class="dot-sw" style="background:{{color-accent-soft}};"></span>--brand-accent-soft</code></td><td><code>{{color-accent-soft}}</code></td><td>Bg badges activos, hover</td></tr>
              <tr><td><code><span class="dot-sw" style="background:{{color-accent-glow}};"></span>--brand-accent-glow</code></td><td><code>{{color-accent-glow}}</code></td><td>Box-shadow glow en CTA, dot pulse</td></tr>
              <tr><td><code><span class="dot-sw" style="background:{{color-ink}};"></span>--brand-bg</code></td><td><code>{{color-ink}}</code></td><td>Canvas pantalla completa</td></tr>
              <tr><td><code><span class="dot-sw" style="background:{{color-white}}; border:1px solid #333;"></span>--brand-fg</code></td><td><code>{{color-white}}</code></td><td>Headings, CTA primario</td></tr>
              <tr><td><code><span class="dot-sw" style="background:{{color-cream}};"></span>--brand-cream</code></td><td><code>{{color-cream}}</code></td><td>Hero cálido alternativo</td></tr>
              <tr><td><code><span class="dot-sw" style="background:{{color-navy}};"></span>--brand-navy</code></td><td><code>{{color-navy}}</code></td><td>Contenido dramático, stories</td></tr>
              <tr><td><code><span class="dot-sw" style="background:{{color-slate}};"></span>--brand-slate</code></td><td><code>{{color-slate}}</code></td><td>Surface oscura elevada</td></tr>
            </tbody>
          </table>
        </div>
      </section>

      <div class="foot-meta">
        <span>{{brand-name}} · brandboard {{brand-meta-version}} · generado por brandboard-creator</span>
        <span>source of truth: <a href="#">{{brand-source-doc}}</a></span>
      </div>

    </div>
  </body>
</html>
