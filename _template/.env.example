# =====================================================================
# .env.example — template ITERA SaaS (Next.js + Prisma 7 + BetterAuth)
# =====================================================================
# Copiar a .env y completar. Prisma CLI solo lee .env (no .env.local).
# Todas las vars marcadas [requerida] son obligatorias para arrancar.
# Las [opcional] solo si vas a usar esa feature.
# Si tu proyecto no usa alguna seccion, borrala entera.
# =====================================================================

# --- Database [requerida] ---
DATABASE_URL="postgresql://postgres:password@localhost:5432/<db_name>?schema=public"

# --- Auth (BetterAuth) [requerida si el proyecto tiene auth] ---
# Generar secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
BETTER_AUTH_SECRET=""
# URL publica. Dev: http://localhost:<port> o http://<sub>.<proyecto>.localhost:<port>
BETTER_AUTH_URL="http://localhost:3000"

# --- Admin bootstrap [requerida si hay panel admin] ---
# Credenciales del primer admin que crea el seed.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
# Bearer para POST /api/admin/seed si el proyecto lo tiene. En dev cualquier string sirve.
ADMIN_SEED_SECRET="dev-seed-secret-local-only"

# --- Cloudflare Turnstile (captcha) [opcional, si hay forms publicos] ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# --- Cloudflare R2 (upload de imagenes) [opcional] ---
# Las 5 o ninguna. Sin esto el upload falla.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""  # ej: https://pub-xxx.r2.dev o dominio custom

# --- Itera Estudio (generacion de imagenes) [opcional] ---
# Bearer token de app.iteraestudio.com/api/v1/generate.
# Docs: ~/projects/itera-core/reference_itera_image_api.md
ITERA_API_KEY=""

# --- Brevo (email transaccional) [opcional, si mandan emails] ---
# SMTP login NO es el email de la cuenta — es el user generado por Brevo.
# Guia del metodo (COMO integrar):  ~/projects/itera-core/reference_brevo_smtp.md
# Inventario de uso (QUE proyectos ya usan la cuenta + cuota): ~/projects/itera-core/reference_brevo_usage_inventory.md
# Antes de configurar estas vars: leer el inventario para confirmar sender/key name unicos.
# Despues de configurar: agregar este proyecto a la tabla del inventario.
BREVO_SMTP_KEY=""
BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT="587"
BREVO_SMTP_USER=""             # ej: a730df001@smtp-brevo.com
BREVO_SENDER_EMAIL=""
BREVO_SENDER_NAME=""

# =====================================================================
# Ops contra prod (opcional) — scripts locales apuntando a prod
# =====================================================================
# Solo si corres migraciones/seeds contra prod desde local. Obtener de Coolify:
#   coolify app env list <app-uuid> --format json -s
# NO dejarlas hardcodeadas si no las estas usando.
# ---------------------------------------------------------------------
# PROD_BETTER_AUTH_URL=""
# PROD_ADMIN_EMAIL=""
# PROD_ADMIN_PASSWORD=""
# PROD_ADMIN_SEED_SECRET=""

# =====================================================================
# Solo en Coolify (NO agregar aca) — documentadas para referencia
# =====================================================================
# ALLOW_DESTRUCTIVE_SCHEMA   → deploys que agregan/alteran constraints via db push
# SKIP_DB_PUSH_ON_START      → escape hatch para arrancar sin db push
# TZ=America/Argentina/Buenos_Aires  → critico para Server Components con fechas
# =====================================================================
